# -----------------------------------------------------------------------
# Admin access
# -----------------------------------------------------------------------
ADMIN_EMAIL=sezaiemrekonuk@gmail.com
ADMIN_PASSWORD=change-me-strong-password

# -----------------------------------------------------------------------
# Web security
# -----------------------------------------------------------------------
# Random string used to sign session cookies. Change this before deploying.
SECRET_KEY=generate-a-random-string-here

# Fernet key used to encrypt stored Hacettepe passwords.
# Generate once with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: if left empty a temporary key is generated on each restart,
# meaning all stored passwords become unreadable after a restart.
FERNET_KEY=

# -----------------------------------------------------------------------
# Gmail (used for ALL forwarding — one sender account for everyone)
# -----------------------------------------------------------------------
GMAIL_SENDER=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# -----------------------------------------------------------------------
# Scraper settings
# -----------------------------------------------------------------------
# How often to check for new mail (seconds, default 900 = 15 min)
POLL_INTERVAL=900

# Set to "1" to run Chromium headless (normal production mode).
# Set to "0" to show a browser window (useful for --auth sessions).
HEADLESS=1

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
# Path to the SQLite database file inside the container.
DB_PATH=/app/data/hub.db
