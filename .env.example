# Hacettepe University credentials
HU_EMAIL=yourusername@hacettepe.edu.tr
HU_PASSWORD=your_hacettepe_password

# Gmail forwarding target + App Password
GMAIL_SENDER=yourapp@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
GMAIL_TARGET=yourtarget@gmail.com

# How often to check for new mail (seconds, default 900 = 15 min)
POLL_INTERVAL=900

# Playwright: set to "1" to run browser with UI (for first-time auth)
HEADLESS=1

# Playwright: directory to persist the login session (cookies).
# Must be writable. Default (if unset in .env) is inside the repo at `.playwright/user_data`.
USER_DATA_DIR=.playwright/user_data
